{
  "name": "vite-plus-cli",
  "version": "0.0.0",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/voidzero-dev/vite-plus.git"
  },
  "bin": {
    "vite": "./bin/vite"
  },
  "files": [
    "bin",
    "dist",
    "AGENTS.md",
    "templates",
    "rules"
  ],
  "scripts": {
    "build": "rolldown -c rolldown.config.ts && oxnode -C dev ./build.ts",
    "copy-binding": "cp ./binding/*.node ./dist",
    "snap-test": "tool snap-test",
    "publish-native": "node ./publish-native-addons.ts"
  },
  "dependencies": {
    "cross-spawn": "catalog:",
    "picocolors": "catalog:"
  },
  "devDependencies": {
    "@clack/prompts": "catalog:",
    "@napi-rs/cli": "catalog:",
    "@oxc-node/core": "catalog:",
    "@types/cross-spawn": "catalog:",
    "@types/semver": "catalog:",
    "@types/validate-npm-package-name": "catalog:",
    "@voidzero-dev/vite-plus-tools": "workspace:",
    "detect-indent": "catalog:",
    "detect-newline": "catalog:",
    "glob": "catalog:",
    "minimatch": "catalog:",
    "mri": "catalog:",
    "oxfmt": "catalog:",
    "rolldown": "workspace:*",
    "semver": "catalog:",
    "validate-npm-package-name": "catalog:",
    "yaml": "catalog:"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "napi": {
    "binaryName": "vite-plus-cli",
    "packageName": "@voidzero-dev/vite-plus-cli",
    "targets": [
      "aarch64-apple-darwin",
      "aarch64-unknown-linux-gnu",
      "x86_64-unknown-linux-gnu",
      "x86_64-pc-windows-msvc"
    ]
  }
}

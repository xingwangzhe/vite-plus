│                                                                                            │
╰────────────────────────────────────────────────────────────────────────────────────────────╯

Done in <variable>ms using pnpm v<semver>"
`;

exports[`replaceUnstableOutput > replace unstable semver version 1`] = `
"foo v<semver>
 v<semver>
 v<semver>
